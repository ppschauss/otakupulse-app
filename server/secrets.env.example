# Vorlage — echte Werte gehören in secrets.env (gitignored).

# Lesender Zugriff auf die OtakuPulse-Datenbank.
# Eigene Rolle mit ausschließlich SELECT-Recht, NICHT der Payload-Benutzer.
CATALOG_DSN=postgresql+psycopg://companion_ro:PASSWORT@otakupulse-db:5432/otakupulse

# Eigene Datenbank im selben Postgres-Container.
COMPANION_DSN=postgresql+psycopg://companion:PASSWORT@otakupulse-db:5432/companion

# Firebase Cloud Messaging (Super-Swipe-Benachrichtigungen).
FCM_PROJECT_ID=
FCM_CREDENTIALS_FILE=/secrets/firebase-service-account.json

# Deckel für die Seitengröße des Swipe-Stapels.
DECK_MAX_PAGE_SIZE=40
